{
  "name": "esbuild-plugin-progress",
  "version": "1.0.1",
  "description": "A plugin to add a progress spinner to esbuild",
  "keywords": [
    "progress",
    "server",
    "esbuild",
    "plugin"
  ],
  "license": "MIT",
  "author": "",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsds build",
    "deploy": "tsds deploy",
    "format": "biome check --write --unsafe src/ test/",
    "test": "tsds test:node --no-timeouts",
    "test:engines": "nvu engines npm test",
    "version": "tsds version"
  },
  "dependencies": {
    "ora": "3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.0",
    "fs-extra": "^11.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-dev-stack": "^1.2.6"
  },
  "engines": {
    "node": ">=12"
  },
  "tsds": {
    "source": "src/index.mjs",
    "targets": [
      "cjs"
    ]
  }
}
